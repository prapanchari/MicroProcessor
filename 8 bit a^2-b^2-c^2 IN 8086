		OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
A DB 03H
B DB 02H
C DB 01H
ANS1 DW 0000H
ANS2 DW 0000H
ANS3 DW 0000H
RESULT DW 0000H
BORROW DB 00H
DATA ENDS
CODE SEGMENT 
	ASSUME CS:CODE,DS:DATA
	MOV AX,DATA
	MOV DS,AX
	MOV CL,00H
	MOV AL,A
	MUL AL
	MOV ANS1,AX
	MOV AL,B
	MUL AL
	MOV ANS2,AX
	MOV AL,C
	MUL AL
	MOV ANS3,AX
	MOV AX,ANS1
	SUB AX,ANS2
	SBB AX,ANS3
	JNC L1
	INC CL
L1:	MOV RESULT,AX
	MOV BORROW,CL
CODE ENDS
END
