		OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DW 0000H,0005H,0002H,0003H,0009H
COUNT EQU 0005H
KEY DW 0002H
RES DB 00H
DATA ENDS
CODE SEGMENT 
	ASSUME CS:CODE,DS:DATA
	MOV AX,DATA
	MOV DS,AX
	MOV CX,COUNT
	MOV SI,OFFSET ARRAY
L1:	MOV AX,[SI]
	CMP AX,KEY
	JZ L2
	INC SI
	INC SI
	LOOP L1
	MOV RES,00H
	JMP L3
L2:	MOV RES,01H
L3:	HLT
CODE ENDS
END
