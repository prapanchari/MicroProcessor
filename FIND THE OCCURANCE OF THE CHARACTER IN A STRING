		OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
STRING1 DB "HELLO FRIENDS"
KEY DB 'L'
RESULT DB 00H
COUNT EQU 05H
DATA ENDS
CODE SEGMENT 
	ASSUME CS:CODE,DS:DATA,ES:DATA
	MOV AX,DATA
	MOV DS,AX
	MOV ES,AX
	CLD
	MOV CL,COUNT
